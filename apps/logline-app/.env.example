# Logging (optional — default info)
# LOG_LEVEL=debug

# GitHub App
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GITHUB_WEBHOOK_SECRET=whsec_example

# GitHub OAuth App (dashboard sign-in — separate from the GitHub App)
GITHUB_OAUTH_CLIENT_ID=Iv1...
GITHUB_OAUTH_CLIENT_SECRET=...

# NextAuth (dashboard sessions)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Optional: signed install state (defaults to NEXTAUTH_SECRET). Install route accepts optional state= when set.
# INSTALL_STATE_SECRET=

# Optional: comma-separated hostnames allowed for custom fanout HTTPS URLs (otherwise only https allowed with hostname check disabled list)
# FANOUT_CUSTOM_URL_ALLOWLIST=api.segment.io,your-proxy.example.com

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# OpenAI (optional — enables LLM-powered event synthesis)
OPENAI_API_KEY=sk-example

# Stripe (optional — enables billing)
STRIPE_SECRET_KEY=sk_test_example
STRIPE_WEBHOOK_SECRET=whsec_stripe_example
STRIPE_PRICE_ID=price_example
BILLING_SUCCESS_URL=https://logline.dev/billing/success
BILLING_CANCEL_URL=https://logline.dev/billing/cancel
