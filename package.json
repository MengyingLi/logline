{
  "name": "logline-cli",
  "version": "0.1.1",
  "description": "Semantic layer for product analytics — generates tracking plans from codebases. The missing piece between event delivery and AI agents.",
  "keywords": [
    "analytics",
    "tracking",
    "product-analytics",
    "segment",
    "amplitude",
    "opentelemetry",
    "ai-agent",
    "cli",
    "typescript"
  ],
  "homepage": "https://github.com/MengyingLi/logline",
  "repository": {
    "type": "git",
    "url": "https://github.com/MengyingLi/logline.git"
  },
  "license": "MIT",
  "author": "Mengying Li",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "logline": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev:scan": "tsx src/cli.ts scan",
    "test": "node --test test/*.test.js",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "glob": "^11.0.3",
    "js-yaml": "^4.1.1",
    "openai": "^4.80.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "conventions",
    "skills",
    "README.md",
    "LICENSE"
  ]
}
